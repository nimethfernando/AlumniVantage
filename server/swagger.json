{
  "openapi": "3.0.0",
  "info": {
    "title": "AlumniVantage API",
    "version": "1.0.0",
    "description": "API documentation for the Phantasmagoria Alumni Influencer Platform. Includes public AR endpoints and secure authenticated routes."
  },
  "servers": [
    {
      "url": "BACKEND_URL_FROM_ENV",
      "description": "Environment-based Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Developer API Key required for AR Client public routes."
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token",
        "description": "Standard JWT authentication stored in an httpOnly cookie."
      },
      "csrfAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "CSRF-Token",
        "description": "CSRF Token required for all POST, PUT, and DELETE requests."
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "email",
          "password"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "example": "Nimeth"
          },
          "last_name": {
            "type": "string",
            "example": "Fernando"
          },
          "email": {
            "type": "string",
            "example": "w1953182@my.westminster.ac.uk"
          },
          "password": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "w1953182@my.westminster.ac.uk"
          },
          "password": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        }
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "w1953182@my.westminster.ac.uk"
          }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": [
          "newPassword"
        ],
        "properties": {
          "newPassword": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        }
      },
      "GenerateApiKeyRequest": {
        "type": "object",
        "properties": {
          "client_name": {
            "type": "string",
            "example": "Eastminster AR Client"
          }
        }
      },
      "ProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "bio": {
            "type": "string",
            "example": "Software Engineering undergraduate interested in backend systems."
          },
          "linkedin_url": {
            "type": "string",
            "example": "https://linkedin.com/in/nimeth"
          },
          "profile_image": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "DegreeRequest": {
        "type": "object",
        "required": [
          "degree_name",
          "completion_date"
        ],
        "properties": {
          "degree_name": {
            "type": "string",
            "example": "BEng Software Engineering"
          },
          "university_url": {
            "type": "string",
            "example": "https://www.westminster.ac.uk"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2026-06-30"
          }
        }
      },
      "CertificationRequest": {
        "type": "object",
        "required": [
          "cert_name",
          "completion_date"
        ],
        "properties": {
          "cert_name": {
            "type": "string",
            "example": "Azure Fundamentals"
          },
          "course_url": {
            "type": "string",
            "example": "https://learn.microsoft.com"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2025-11-10"
          }
        }
      },
      "LicenseRequest": {
        "type": "object",
        "required": [
          "license_name",
          "completion_date"
        ],
        "properties": {
          "license_name": {
            "type": "string",
            "example": "Professional Cloud Architect"
          },
          "awarding_body_url": {
            "type": "string",
            "example": "https://cloud.google.com"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2025-12-15"
          }
        }
      },
      "CourseRequest": {
        "type": "object",
        "required": [
          "course_name",
          "completion_date"
        ],
        "properties": {
          "course_name": {
            "type": "string",
            "example": "Advanced Node.js"
          },
          "course_url": {
            "type": "string",
            "example": "https://udemy.com"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2025-09-20"
          }
        }
      },
      "EmploymentRequest": {
        "type": "object",
        "required": [
          "job_title",
          "company_name",
          "start_date"
        ],
        "properties": {
          "job_title": {
            "type": "string",
            "example": "Software Engineer Intern"
          },
          "company_name": {
            "type": "string",
            "example": "Orel IT"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "example": "2025-01-01"
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "example": "2025-06-30"
          }
        }
      },
      "BidRequest": {
        "type": "object",
        "required": [
          "amount"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "example": 250
          }
        }
      },
      "ApiKeyListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "client_name": {
            "type": "string",
            "example": "Eastminster AR Client"
          },
          "is_revoked": {
            "type": "boolean",
            "example": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-28T10:30:00.000Z"
          }
        }
      },
      "ApiKeyStatsItem": {
        "type": "object",
        "properties": {
          "client_name": {
            "type": "string",
            "example": "Eastminster AR Client"
          },
          "api_key": {
            "type": "string",
            "example": "dev_key_a1b2c3d4e5f6g7h8"
          },
          "is_revoked": {
            "type": "boolean",
            "example": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-28T10:30:00.000Z"
          },
          "last_used_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-03-28T12:45:00.000Z"
          },
          "usage_count": {
            "type": "integer",
            "example": 12
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "API Health Check",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "Welcome to the AlumniVantage API"
          }
        }
      }
    },
    "/api/csrf-token": {
      "get": {
        "summary": "Fetch CSRF Token",
        "description": "Retrieves a CSRF token to be used in the headers of subsequent state-changing requests.",
        "tags": [
          "Security"
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved CSRF token."
          }
        }
      }
    },
    "/api/public/featured-alumnus": {
      "get": {
        "summary": "Get today's featured alumnus",
        "description": "Retrieves the profile of the alumnus who won the daily bid. Designed for the AR Client.",
        "tags": [
          "Public Developer API"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved the featured alumnus."
          },
          "401": {
            "description": "Access denied. API Key is missing."
          }
        }
      }
    },
    "/api/dev/api-keys": {
      "post": {
        "summary": "Generate API Key",
        "description": "Creates a new developer API key for public client access.",
        "tags": [
          "Developer API Keys"
        ],
        "security": [
          {
            "cookieAuth": []
          },
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "API key generated successfully."
          },
          "401": {
            "description": "Unauthorized. Login required."
          }
        }
      },
      "get": {
        "summary": "View API Keys List",
        "description": "Retrieves the list of developer API keys showing ID, name, revoked status, and created date.",
        "tags": [
          "Developer API Keys"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved API keys list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKeyListItem"
                  }
                },
                "example": [
                  {
                    "id": 1,
                    "client_name": "Eastminster AR Client",
                    "is_revoked": false,
                    "created_at": "2026-03-28T10:30:00.000Z"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Unauthorized. Login required."
          }
        }
      }
    },
    "/api/dev/api-keys/{id}/stats": {
      "get": {
        "summary": "View API Key Statistics by ID",
        "description": "Retrieves statistics for a specific API key using its ID.",
        "tags": [
          "Developer API Keys"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID of the API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved API key statistics.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyStatsItem"
                },
                "example": {
                  "client_name": "Eastminster AR Client",
                  "api_key": "dev_key_a1b2c3d4e5f6g7h8",
                  "is_revoked": false,
                  "created_at": "2026-03-28T10:30:00.000Z",
                  "last_used_at": "2026-03-28T12:45:00.000Z",
                  "usage_count": 12
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Login required."
          },
          "404": {
            "description": "API key not found."
          }
        }
      }
    },
    "/api/dev/api-keys/{id}/revoke": {
      "put": {
        "summary": "Revoke an API key",
        "description": "Marks an API key as revoked so it can no longer be used.",
        "tags": [
          "Developer API Keys"
        ],
        "security": [
          {
            "cookieAuth": []
          },
          {
            "csrfAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API key revoked successfully."
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "API key not found"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully registered."
          },
          "400": {
            "description": "Validation failed."
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "User Login",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully logged in. JWT set in cookie."
          },
          "401": {
            "description": "Invalid email or password."
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "User Logout",
        "description": "Clears the JWT authentication cookie.",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "csrfAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully logged out."
          }
        }
      }
    },
    "/api/auth/verify/{token}": {
      "get": {
        "summary": "Verify Email Address",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Email verification token"
          }
        ],
        "responses": {
          "200": {
            "description": "Email successfully verified."
          },
          "400": {
            "description": "Invalid or expired verification token."
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "summary": "Request Password Reset",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset email sent."
          }
        }
      }
    },
    "/api/auth/reset-password/{token}": {
      "post": {
        "summary": "Reset Password",
        "description": "Submit the token received via terminal/email to create a new password.",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "csrfAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Reset token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password successfully reset."
          },
          "400": {
            "description": "Invalid or expired reset token."
          }
        }
      }
    },
    "/api/profile": {
      "get": {
        "summary": "Get Current User Profile",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Profile data retrieved successfully."
          }
        }
      },
      "post": {
        "summary": "Create or Update User Profile",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "cookieAuth": []
          },
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "bio": {
                    "type": "string"
                  },
                  "linkedin_url": {
                    "type": "string"
                  },
                  "profile_image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile created or updated successfully."
          }
        }
      },
      "delete": {
        "summary": "Delete User Profile",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "cookieAuth": []
          },
          {
            "csrfAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Profile deleted successfully."
          }
        }
      }
    },
    "/api/profile/completion": {
      "get": {
        "summary": "Get Profile Completion Status",
        "description": "Calculates the user's profile completion percentage and lists completed and missing profile sections.",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Profile completion status retrieved successfully."
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
