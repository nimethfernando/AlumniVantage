{
  "openapi": "3.0.0",
  "info": {
    "title": "AlumniVantage API",
    "version": "1.0.0",
    "description": "API documentation for the Phantasmagoria Alumni Influencer Platform. Includes public AR endpoints and secure authenticated routes."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Developer API Key required for AR Client public routes."
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token",
        "description": "Standard JWT authentication stored in an httpOnly cookie."
      },
      "csrfAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "CSRF-Token",
        "description": "CSRF Token required for all POST, PUT, and DELETE requests."
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["first_name", "last_name", "email", "password"],
        "properties": {
          "first_name": {
            "type": "string",
            "example": "Nimeth"
          },
          "last_name": {
            "type": "string",
            "example": "Fernando"
          },
          "email": {
            "type": "string",
            "example": "w1953182@my.westminster.ac.uk"
          },
          "password": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "example": "w1953182@my.westminster.ac.uk"
          },
          "password": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        }
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "example": "w1953182@my.westminster.ac.uk"
          }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": ["newPassword"],
        "properties": {
          "newPassword": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        }
      },
      "GenerateApiKeyRequest": {
        "type": "object",
        "properties": {
          "client_name": {
            "type": "string",
            "example": "Eastminster AR Client"
          }
        }
      },
      "ProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "bio": {
            "type": "string",
            "example": "Software Engineering undergraduate interested in backend systems."
          },
          "linkedin_url": {
            "type": "string",
            "example": "https://linkedin.com/in/nimeth"
          },
          "profile_image": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "DegreeRequest": {
        "type": "object",
        "required": ["degree_name", "completion_date"],
        "properties": {
          "degree_name": {
            "type": "string",
            "example": "BEng Software Engineering"
          },
          "university_url": {
            "type": "string",
            "example": "https://www.westminster.ac.uk"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2026-06-30"
          }
        }
      },
      "CertificationRequest": {
        "type": "object",
        "required": ["cert_name", "completion_date"],
        "properties": {
          "cert_name": {
            "type": "string",
            "example": "Azure Fundamentals"
          },
          "course_url": {
            "type": "string",
            "example": "https://learn.microsoft.com"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2025-11-10"
          }
        }
      },
      "LicenseRequest": {
        "type": "object",
        "required": ["license_name", "completion_date"],
        "properties": {
          "license_name": {
            "type": "string",
            "example": "Professional Cloud Architect"
          },
          "awarding_body_url": {
            "type": "string",
            "example": "https://cloud.google.com"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2025-12-15"
          }
        }
      },
      "CourseRequest": {
        "type": "object",
        "required": ["course_name", "completion_date"],
        "properties": {
          "course_name": {
            "type": "string",
            "example": "Advanced Node.js"
          },
          "course_url": {
            "type": "string",
            "example": "https://udemy.com"
          },
          "completion_date": {
            "type": "string",
            "format": "date",
            "example": "2025-09-20"
          }
        }
      },
      "EmploymentRequest": {
        "type": "object",
        "required": ["job_title", "company_name", "start_date"],
        "properties": {
          "job_title": {
            "type": "string",
            "example": "Software Engineer Intern"
          },
          "company_name": {
            "type": "string",
            "example": "Orel IT"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "example": "2025-01-01"
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "example": "2025-06-30"
          }
        }
      },
      "BidRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": {
            "type": "number",
            "example": 250
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "API Health Check",
        "tags": ["General"],
        "responses": {
          "200": {
            "description": "Welcome to the AlumniVantage API"
          }
        }
      }
    },
    "/api/csrf-token": {
      "get": {
        "summary": "Fetch CSRF Token",
        "description": "Retrieves a CSRF token to be used in the headers of subsequent state-changing requests.",
        "tags": ["Security"],
        "responses": {
          "200": {
            "description": "Successfully retrieved CSRF token."
          }
        }
      }
    },
    "/api/public/featured-alumnus": {
      "get": {
        "summary": "Get today's featured alumnus",
        "description": "Retrieves the profile of the alumnus who won the daily bid. Designed for the AR Client.",
        "tags": ["Public Developer API"],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved the featured alumnus."
          },
          "401": {
            "description": "Access denied. API Key is missing."
          }
        }
      }
    },
    "/api/dev/api-keys": {
      "post": {
        "summary": "Generate API Key",
        "description": "Creates a new developer API key for public client access.",
        "tags": ["Developer API Keys"],
        "security": [
          {
            "cookieAuth": []
          },
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "API key generated successfully."
          },
          "401": {
            "description": "Unauthorized. Login required."
          }
        }
      },
      "get": {
        "summary": "View API Keys List",
        "description": "Retrieves the list of developer API keys.",
        "tags": ["Developer API Keys"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved API keys list."
          },
          "401": {
            "description": "Unauthorized. Login required."
          }
        }
      }
    },
    "/api/dev/api-keys/stats": {
      "get": {
        "summary": "View API Key Statistics",
        "description": "Retrieves usage statistics for developer API keys, including last used time and usage count.",
        "tags": ["Developer API Keys"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved API key statistics."
          },
          "401": {
            "description": "Unauthorized. Login required."
          }
        }
      }
    },
    "/api/dev/api-keys/{id}/revoke": {
      "put": {
        "summary": "Revoke an API key",
        "description": "Marks an API key as revoked so it can no longer be used.",
        "tags": ["Developer API Keys"],
        "security": [
          {
            "cookieAuth": []
          },
          {
            "csrfAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID of the API key to revoke"
          }
        ],
        "responses": {
          "200": {
            "description": "API key revoked successfully."
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "API key not found"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Authentication"],
        "security": [
          {
            "csrfAuth": []
          }
        ],
        "requestBody": {
          "required": true,
