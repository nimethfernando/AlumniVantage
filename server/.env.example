# ==========================================
# SERVER CONFIGURATION
# ==========================================
# The port on which the Express server will run (Default is 3000)
PORT=3000
# Environment mode (development or production)
NODE_ENV=development

# ==========================================
# URL & CORS CONFIGURATION
# ==========================================
# The URL of your frontend application (used for CORS and CSP)
FRONTEND_URL=http://localhost:5173
# The URL of your backend API (used for Swagger and CSP)
BACKEND_URL=http://localhost:3000
# Comma-separated list of allowed origins for CORS (no spaces after commas)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# DATABASE CONFIGURATION (MySQL)
# ==========================================
# The hostname of your MySQL database (e.g., localhost or a remote IP/URL)
DB_HOST=localhost
# The username for your MySQL database (e.g., root)
DB_USER=root
# The password for your MySQL database user
DB_PASSWORD=your_mysql_password_here
# The name of the database you created for AlumniVantage
DB_NAME=alumnivantage_db

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
# A random, secure secret string used to sign JSON Web Tokens (JWT)
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ==========================================
# EMAIL SERVICE (Nodemailer)
# ==========================================
# The Gmail address used to send out verification, reset, and bid emails
EMAIL_USER=your_email@gmail.com
# The 16-character App Password generated from your Google Account settings 
# DO NOT use your normal Google account password!
EMAIL_PASS=your_16_char_app_password