# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# The base URL of your backend API server. 
# For local development, this is usually http://localhost:3000
VITE_API_URL=http://localhost:3000

# ==========================================
# PUBLIC API KEYS
# ==========================================
# API key required to access the Analytics dashboard endpoints
VITE_ANALYTICS_API_KEY=your_analytics_api_key_here

# API key required to access the public Alumni Directory endpoints
VITE_ALUMNI_API_KEY=your_alumni_api_key_here